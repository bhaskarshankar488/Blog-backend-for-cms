# --- Cloudflare Turnstile ---
# Secret key from your Turnstile widget dashboard (never expose this to the client)
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here

# --- Rate limiting for POST /api/v1/public/subscribe ---
# Window size in milliseconds (default: 900000 = 15 minutes)
SUBSCRIBE_RATE_LIMIT_WINDOW_MS=900000
# Max requests allowed per IP per window (default: 5)
SUBSCRIBE_RATE_LIMIT_MAX_REQUESTS=5
