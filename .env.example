PORT=5000

MONGO_URI=mongodb://127.0.0.1:27017/AI_Corner_Database

ADMIN_EMAIL=admin@system.com
ADMIN_PASSWORD=admin123

# =========================================
# Public Google Authentication
# =========================================

PUBLIC_GOOGLE_CLIENT_ID=
PUBLIC_GOOGLE_CLIENT_SECRET=

# =========================================
# Public JWT
# =========================================

PUBLIC_AUTH_ACCESS_TOKEN_SECRET=

PUBLIC_AUTH_REFRESH_TOKEN_SECRET=

PUBLIC_AUTH_ACCESS_TOKEN_EXPIRES_IN=15m

PUBLIC_AUTH_REFRESH_TOKEN_EXPIRES_IN=7d

PUBLIC_AUTH_JWT_ISSUER=blog-cms-api

PUBLIC_AUTH_JWT_AUDIENCE=blog-public-client

# =========================================
# Cookies
# =========================================

PUBLIC_AUTH_ACCESS_COOKIE_NAME=public_access_token

PUBLIC_AUTH_REFRESH_COOKIE_NAME=public_refresh_token

PUBLIC_AUTH_COOKIE_SECURE=false

PUBLIC_AUTH_COOKIE_SAME_SITE=lax

PUBLIC_AUTH_COOKIE_DOMAIN=

PUBLIC_AUTH_COOKIE_PATH=/

# =========================================
# Frontends
# =========================================

FRONTEND_URL_CMS=http://localhost:5173

FRONTEND_URL_PUBLIC=http://localhost:3000


# --- Cloudflare Turnstile ---
# Secret key from your Turnstile widget dashboard (never expose this to the client)
TURNSTILE_SECRET_KEY=

# --- Rate limiting for POST /api/v1/public/subscribe ---
# Window size in milliseconds (default: 900000 = 15 minutes)
SUBSCRIBE_RATE_LIMIT_WINDOW_MS=900000
# Max requests allowed per IP per window (default: 5)
SUBSCRIBE_RATE_LIMIT_MAX_REQUESTS=5